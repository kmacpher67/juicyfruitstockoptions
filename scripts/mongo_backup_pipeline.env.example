# Copy to scripts/mongo_backup_pipeline.env and adjust values.

# Optional: Google Drive folder ID for native upload+verify+retention.
DRIVE_FOLDER_ID=143kk-X98X-JBuA-73ZI9GfpOrX3fvKok

# Token source (choose one):
# 1) direct token env var (short-lived)
# DRIVE_ACCESS_TOKEN=ya29....
# 2) token command (recommended for automation if available)
# DRIVE_ACCESS_TOKEN_CMD=gcloud auth print-access-token

# Drive retention policy
DRIVE_RETENTION_DAYS=30
DRIVE_RETENTION_KEEP_MIN=10

# Local retention policy
RETAIN_ARTIFACT_DAYS=14
RETAIN_PACKAGE_DAYS=30
