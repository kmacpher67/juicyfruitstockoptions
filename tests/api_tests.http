@baseUrl = http://localhost:8000
@username = admin
@password = password123

### 1. Login and Get Token
# @name login
POST {{baseUrl}}/token
Content-Type: application/x-www-form-urlencoded

username={{username}}&password={{password}}

### 
@authToken = {{login.response.body.access_token}}

### 2. Get Dividend Capture Analysis (Persisted Results)
GET {{baseUrl}}/analysis/dividend-capture
Authorization: Bearer {{authToken}}

### 3. Force Scan Dividend Capture (Live Fetching)
GET {{baseUrl}}/analysis/dividend-capture?force_scan=true
Authorization: Bearer {{authToken}}

### 4. Scan Specific Ticker for Dividend Strategy
GET {{baseUrl}}/analysis/dividend-capture/MSTR
Authorization: Bearer {{authToken}}

### 5. Run Live Comparison
POST {{baseUrl}}/run/stock-live-comparison
Authorization: Bearer {{authToken}}
